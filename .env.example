# ═══════════════════════════════════════════════════════════
# Andalusia Booking Bot — Environment Variables Template
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# OpenRouter LLM
OPENROUTER_API_KEY=your_openrouter_api_key_here

# SQL Server
DB_SERVER=your_db_server_ip
DB_DATABASE=your_database_name
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Dynamics 365 CRM — doctor reference data incl. walk-in / cash price
# CRM_SERVER is the TDS endpoint: "<org>.crm<N>.dynamics.com,5558"
CRM_SERVER=org2f45e702.crm4.dynamics.com,5558
CRM_CLIENT_ID=51f81489-12ee-4a9e-aaae-a2591f45987d
CRM_TENANT=organizations
CRM_USERNAME=your_crm_user@yourtenant.net
# CRM_PASSWORD is only used when MFA is disabled on the account.
# With MFA on, leave it empty and auth runs interactively (browser) on first
# use — MSAL then persists a refresh token to MSAL_TOKEN_CACHE_PATH.
CRM_PASSWORD=
CRM_DOCTOR_TABLE=dbo.cr301_newdoctordataset
CRM_FEE_TABLE=dbo.cr301_table1
CRM_PRICE_CACHE_TTL_SECONDS=86400
# Disable the interactive browser flow on a headless server (set to 0).
# Default 1 = enabled (dev / first-run setup).
CRM_ALLOW_INTERACTIVE=1
# Override where the MSAL refresh-token cache lives. Default: ~/.andalusia_crm_cache.bin
# MSAL_TOKEN_CACHE_PATH=/opt/andalusia/crm_cache.bin

# View Mode (stakeholder / dev)
VIEW_MODE=stakeholder

# ═══════════════════════════════════════════════════════════
# Production-hardening knobs — every value below defaults to current
# behavior, so an unchanged .env keeps the production flow identical.
# ═══════════════════════════════════════════════════════════

# ─── Logging ───────────────────────────────────────────────
# Per-LLM-call ledger: one row per call_llm() invocation in chat_logs.db.
# Set to 0 to disable entirely (kill switch — leaves the booking flow alone).
LOG_LLM_CALLS=1
# Override the chat-log SQLite file location. Leave unset for the repo default
# (db/chat_logs.db). Set to e.g. /var/log/andalusia/chat_logs.db for a shared
# volume.
# LOG_DB_PATH=

# ─── Per-call model routing (Stage 4) ──────────────────────
# Override the OpenRouter model for individual labels. Defaults fall back to
# OPENROUTER_MODEL above. Useful to route cheap labels (intent, time_parse)
# to a smaller model when ops wants to cut cost without touching code.
# OPENROUTER_MODEL_CONVERSATION=meta-llama/llama-3.3-70b-instruct
# OPENROUTER_MODEL_ROUTING=meta-llama/llama-3.3-70b-instruct
# OPENROUTER_MODEL_INTENT=meta-llama/llama-3.3-70b-instruct
# OPENROUTER_MODEL_TRIAGE=meta-llama/llama-3.3-70b-instruct
# OPENROUTER_MODEL_TIME_PARSE=meta-llama/llama-3.3-70b-instruct

# ─── Reliability / timeouts (Stage 2) ──────────────────────
# HTTP timeout on the OpenRouter call (seconds). Matches the current hard-coded value.
LLM_TIMEOUT_SECONDS=30
# pyodbc.connect timeout for hospital SQL Server (seconds).
DB_QUERY_TIMEOUT_SECONDS=15
# Hospital DB connection pool size + max age before recycling stale conns.
DB_POOL_MAX_SIZE=10
DB_POOL_MAX_AGE_SECONDS=300

# ─── Feature flags (later stages) ──────────────────────────
# Stage 4: opt-in OpenRouter prompt-caching hints.
OPENROUTER_PROMPT_CACHING=0
# Stage 4: local response cache for intent + time_parse classification.
RESPONSE_CACHE_ENABLED=1
# Stage 5: LangGraph checkpointer. 'memory' enables in-memory checkpointing;
# 'none' (default) keeps the current Streamlit-only state model.
LANGGRAPH_CHECKPOINTER=none

